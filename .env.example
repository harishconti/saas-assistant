# ─────────────────────────────────────────────────────────────────────────────
# SaaS Assistant — Environment Variables
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# Generate a random secure key: python -c "import secrets; print('sk-' + secrets.token_hex(16))"
LITELLM_MASTER_KEY=sk-change-me

# The base URL agents use to reach LiteLLM proxy (from host, not Docker network)
LITELLM_BASE_URL=http://localhost:4000

# ── LLM Providers ────────────────────────────────────────────────────────────
# OpenRouter (primary cloud LLM provider: Gemini 2.5 Flash, Ministral, Kimi K2, Qwen, Minimax)
OPENROUTER_API_KEY=sk-or-v1-...

# Z.ai (GLM-4.7 coding model for the Developer agent)
ZAI_API_KEY=...

# ── Observability (Langfuse) ──────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Memory: PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=saas_assistant
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://saas_user:change-me-strong-password@localhost:5432/saas_assistant

# ── Memory: Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Retrieval: Airweave ───────────────────────────────────────────────────────
AIRWEAVE_API_KEY=aw-...
AIRWEAVE_COLLECTION_ID=saas-project
AIRWEAVE_BASE_URL=https://app.airweave.ai

# ── Long-term Preferences: Mem0 ───────────────────────────────────────────────
MEM0_API_KEY=m0-...

# ── Code Execution ────────────────────────────────────────────────────────────
# GitHub PAT for the Developer agent to read/write repo branches
GITHUB_PAT=ghp_...

# ── Sandbox (Railway ComputeSDK) ──────────────────────────────────────────────
# If these are not set, the Tester agent will use mock execution mode.
# SANDBOX_ENDPOINT_URL=https://your-sandbox.up.railway.app
# SANDBOX_API_KEY=your-sandbox-api-key

# ── Optional: Direct cloud LLM fallbacks (not required if using OpenRouter) ──
# GEMINI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
